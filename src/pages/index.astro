---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 4em 0 3em;
				text-align: center;
			}
			.hero-greeting {
				font-size: 1em;
				color: var(--text-muted);
				margin-bottom: 0.5em;
				font-weight: 500;
			}
			.hero h1 {
				font-size: 3em;
				margin-bottom: 0.3em;
				background: linear-gradient(135deg, var(--accent), #a78bfa);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.hero-tagline {
				font-size: 1.15em;
				color: var(--text-muted);
				margin-bottom: 1.5em;
				font-weight: 400;
			}
			.hero-bio {
				max-width: 520px;
				margin: 0 auto 2em;
				color: var(--text-muted);
				line-height: 1.7;
				font-size: 0.95em;
			}
			.hero-links {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.75em;
				flex-wrap: wrap;
			}
			.hero-links a {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.5em 1em;
				border: 1px solid var(--border);
				border-radius: var(--radius);
				color: var(--text-muted);
				font-size: 0.85em;
				font-weight: 500;
				text-decoration: none;
				transition: all var(--transition);
			}
			.hero-links a:hover {
				color: var(--text);
				border-color: var(--accent);
				background: var(--accent-light);
				transform: translateY(-1px);
			}
			.hero-links a svg {
				width: 16px;
				height: 16px;
			}

			/* Latest Posts Section */
			.section-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin-bottom: 1.5em;
				padding-bottom: 0.75em;
				border-bottom: 1px solid var(--border);
			}
			.section-header h2 {
				font-size: 1.3em;
				font-weight: 600;
				margin: 0;
			}
			.section-header a {
				font-size: 0.85em;
				color: var(--text-muted);
				font-weight: 500;
			}
			.section-header a:hover {
				color: var(--accent);
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			.post-item {
				display: block;
				padding: 1em 0;
				border-bottom: 1px solid var(--border);
				text-decoration: none;
				transition: background-color var(--transition);
			}
			.post-item:last-child {
				border-bottom: none;
			}
			.post-item:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-size: 1.05em;
				font-weight: 600;
				color: var(--text);
				margin: 0 0 0.25em;
				transition: color var(--transition);
			}
			.post-meta {
				font-size: 0.8em;
				color: var(--text-light);
			}
			.post-desc {
				font-size: 0.85em;
				color: var(--text-muted);
				margin: 0.35em 0 0;
				line-height: 1.5;
			}

			@media (max-width: 720px) {
				.hero {
					padding: 2.5em 0 2em;
				}
				.hero h1 {
					font-size: 2.2em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="hero-greeting">Hey, I'm</p>
				<h1>Bhavesh Panjala</h1>
				<p class="hero-tagline">CS Graduate · Spring Boot Developer · DSA Enthusiast</p>
				<p class="hero-bio">
					I love building scalable backend systems with Spring Boot, solving algorithmic
					challenges, and exploring system design patterns. Welcome to my corner of the internet.
				</p>
				<div class="hero-links">
					<a href="https://github.com/FlameZenith" target="_blank">
						<svg viewBox="0 0 16 16"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
						GitHub
					</a>
					<a href="https://www.linkedin.com/in/bhavesh-panjala-a2488030a/" target="_blank">
						<svg viewBox="0 0 24 24"><path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						LinkedIn
					</a>
					<a href="https://leetcode.com/u/bhaveshpanjala/" target="_blank">
						<svg viewBox="0 0 24 24"><path fill="currentColor" d="M13.483 0a1.374 1.374 0 0 0-.961.438L7.116 6.226l-3.854 4.126a5.266 5.266 0 0 0-1.209 2.104 5.35 5.35 0 0 0-.125.513 5.527 5.527 0 0 0 .062 2.362 5.83 5.83 0 0 0 .349 1.017 5.938 5.938 0 0 0 1.271 1.818l4.277 4.193.039.038c2.248 2.165 5.852 2.133 8.063-.074l2.396-2.392c.54-.54.54-1.414.003-1.955a1.378 1.378 0 0 0-1.951-.003l-2.396 2.392a3.021 3.021 0 0 1-4.205.038l-.02-.019-4.276-4.193c-.652-.64-.972-1.469-.948-2.263a2.68 2.68 0 0 1 .066-.523 2.545 2.545 0 0 1 .619-1.164L9.13 8.114c1.058-1.134 3.204-1.27 4.43-.278l3.501 2.831c.593.48 1.461.387 1.94-.207a1.384 1.384 0 0 0-.207-1.943l-3.5-2.831c-.8-.647-1.766-1.045-2.774-1.202l2.015-2.158A1.384 1.384 0 0 0 13.483 0zm-2.866 12.815a1.38 1.38 0 0 0-1.38 1.382 1.38 1.38 0 0 0 1.38 1.382H20.79a1.38 1.38 0 0 0 1.38-1.382 1.38 1.38 0 0 0-1.38-1.382z"/></svg>
						LeetCode
					</a>
					<a href="https://codeforces.com/profile/Flame_Zenith" target="_blank">
						<svg viewBox="0 0 24 24"><path fill="currentColor" d="M4.5 7.5C5.328 7.5 6 8.172 6 9v10.5c0 .828-.672 1.5-1.5 1.5h-3C.672 21 0 20.328 0 19.5V9c0-.828.672-1.5 1.5-1.5h3zm9-4.5c.828 0 1.5.672 1.5 1.5v15c0 .828-.672 1.5-1.5 1.5h-3c-.828 0-1.5-.672-1.5-1.5v-15c0-.828.672-1.5 1.5-1.5h3zm9 7.5c.828 0 1.5.672 1.5 1.5v7.5c0 .828-.672 1.5-1.5 1.5h-3c-.828 0-1.5-.672-1.5-1.5V12c0-.828.672-1.5 1.5-1.5h3z"/></svg>
						Codeforces
					</a>
				</div>
			</section>

			<section>
				<div class="section-header">
					<h2>Latest Posts</h2>
					<a href="/blog">View all →</a>
				</div>
				<div class="post-list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-item">
							<h3 class="post-title">{post.data.title}</h3>
							<span class="post-meta">
								<FormattedDate date={post.data.pubDate} />
							</span>
							<p class="post-desc">{post.data.description}</p>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
