---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description="Thoughts on software engineering, DSA, system design, and more." />
		<style>
			.page-header {
				margin-bottom: 2em;
			}
			.page-header h1 {
				font-size: 2em;
				margin-bottom: 0.25em;
			}
			.page-header p {
				color: var(--text-muted);
				font-size: 0.95em;
				margin: 0;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-link {
				display: block;
				padding: 1.25em 0;
				border-bottom: 1px solid var(--border);
				text-decoration: none;
				transition: background-color var(--transition);
			}
			.post-link:first-child {
				border-top: 1px solid var(--border);
			}
			.post-link:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-size: 1.1em;
				font-weight: 600;
				color: var(--text);
				margin: 0 0 0.3em;
				transition: color var(--transition);
			}
			.post-meta {
				font-size: 0.8em;
				color: var(--text-light);
				margin-bottom: 0.35em;
			}
			.post-desc {
				font-size: 0.88em;
				color: var(--text-muted);
				margin: 0;
				line-height: 1.5;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Blog</h1>
				<p>Thoughts on software engineering, DSA, system design, and competitive programming.</p>
			</div>
			<div class="post-list">
				{posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="post-link">
						<h2 class="post-title">{post.data.title}</h2>
						<div class="post-meta">
							<FormattedDate date={post.data.pubDate} />
						</div>
						<p class="post-desc">{post.data.description}</p>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
